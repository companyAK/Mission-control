# Database - Use PostgreSQL for production (Vercel/Supabase)
# For local dev: postgresql://user:password@localhost:5432/mission_control
# For Supabase: Get from Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres:your-password@your-host.supabase.co:5432/postgres"

# Authentication - CRITICAL: Change these for production!
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-generated-secret-here"

# Default User (created on first database seed)
DEFAULT_USERNAME="amadu"
DEFAULT_PASSWORD="change-this-to-secure-password"

# OpenClaw API (optional - for future integration)
OPENCLAW_API_URL="http://localhost:8080"
OPENCLAW_API_KEY="your-openclaw-api-key"
